{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.you-box.com/contracts/agent-auth.json",
  "title": "YouBox Agent Auth API",
  "description": "Contract for desktop agent authentication against YouBox Core",
  "definitions": {
    "AuthorizeRequest": {
      "type": "object",
      "required": [
        "client_id",
        "device_id",
        "device_label",
        "state",
        "code_challenge",
        "code_challenge_method"
      ],
      "properties": {
        "client_id": { "type": "string", "const": "youbox-agent" },
        "device_id": { "type": "string", "minLength": 8, "maxLength": 128 },
        "device_label": { "type": "string", "minLength": 1, "maxLength": 128 },
        "state": { "type": "string", "minLength": 8, "maxLength": 128 },
        "code_challenge": { "type": "string", "minLength": 43, "maxLength": 128 },
        "code_challenge_method": { "type": "string", "const": "S256" }
      },
      "additionalProperties": false
    },
    "AuthorizeResponse": {
      "type": "object",
      "required": ["code", "redirect_uri", "expires_in"],
      "properties": {
        "code": { "type": "string", "minLength": 32 },
        "redirect_uri": { "type": "string", "pattern": "^youbox-agent://auth" },
        "expires_in": { "type": "integer", "minimum": 60, "maximum": 600 }
      }
    },
    "ExchangeRequest": {
      "type": "object",
      "required": ["code", "client_id", "device_id", "device_label", "state", "code_verifier"],
      "properties": {
        "code": { "type": "string" },
        "client_id": { "type": "string", "const": "youbox-agent" },
        "device_id": { "type": "string", "minLength": 8, "maxLength": 128 },
        "device_label": { "type": "string", "minLength": 1, "maxLength": 128 },
        "state": { "type": "string" },
        "code_verifier": { "type": "string", "minLength": 43, "maxLength": 128 },
        "platform": { "type": "string" },
        "app_version": { "type": "string" }
      }
    },
    "RefreshRequest": {
      "type": "object",
      "required": ["refresh_token", "client_id", "device_id", "grant_id"],
      "properties": {
        "refresh_token": { "type": "string" },
        "client_id": { "type": "string", "const": "youbox-agent" },
        "device_id": { "type": "string", "minLength": 8, "maxLength": 128 },
        "grant_id": { "type": "integer", "minimum": 1 }
      }
    },
    "TokenResponse": {
      "type": "object",
      "required": ["access_token", "refresh_token", "gateway_token", "token_type", "expires_in", "grant_id"],
      "properties": {
        "access_token": { "type": "string" },
        "refresh_token": { "type": "string" },
        "gateway_token": { "type": "string", "pattern": "^sk-" },
        "token_type": { "type": "string", "const": "Bearer" },
        "expires_in": { "type": "integer", "minimum": 300 },
        "grant_id": { "type": "integer", "minimum": 1 }
      }
    },
    "JWKSResponse": {
      "type": "object",
      "required": ["keys"],
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kty", "kid", "use", "alg", "n", "e"],
            "properties": {
              "kty": { "type": "string", "const": "RSA" },
              "kid": { "type": "string" },
              "use": { "type": "string", "const": "sig" },
              "alg": { "type": "string", "const": "RS256" },
              "n": { "type": "string" },
              "e": { "type": "string" }
            }
          }
        }
      }
    },
    "IntrospectResponse": {
      "type": "object",
      "required": ["active"],
      "properties": {
        "active": { "type": "boolean" },
        "sub": { "type": "string" },
        "scope": { "type": "string" },
        "status": { "type": "integer" }
      }
    },
    "AccountResponse": {
      "type": "object",
      "required": ["id", "display_name", "status", "quota"],
      "properties": {
        "id": { "type": "integer" },
        "display_name": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "integer" },
        "quota": { "type": "integer" },
        "used_quota": { "type": "integer" },
        "subscription_summary": { "type": "object" }
      }
    }
  }
}
